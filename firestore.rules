rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For now, no admins defined, but we provide the helper for future use
      return false;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.id == request.auth.uid || isAdmin());
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (
        isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'ratingCount'])
      );
    }

    // --- Missions ---
    function isValidMission(data) {
      return data.driverId is string &&
             data.status is string &&
             data.userLocation is map && 
             data.userLocation.lat is number && data.userLocation.lng is number;
    }

    match /missions/{missionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Broad list allowed, client must filter by status or roles which are validated per doc
      
      allow create: if isSignedIn() && 
        isValidMission(incoming()) && 
        incoming().driverId == request.auth.uid;

      allow update: if isSignedIn() && (
        // Action: Driver Update (Cancel, Rating, Chat)
        (existing().driverId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'description', 'updatedAt', 'rating', 'reviewComment', 'assignedWorkshopId', 'workshopId', 'chatId'])) ||
        
        // Action: Workshop bidding (Submit Offer)
        ((existing().status == 'searching' || existing().status == 'scheduled') && 
         incoming().diff(existing()).affectedKeys().hasOnly(['offers', 'updatedAt'])) ||

        // Action: Driver accept offer
        (existing().driverId == request.auth.uid && (existing().status == 'searching' || existing().status == 'scheduled') &&
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'assignedWorkshopId', 'workshopId', 'estimatedPrice', 'eta', 'updatedAt', 'chatId'])) ||

        // Action: Workshop Accept (direct)
        ((existing().status == 'searching' || existing().status == 'scheduled') && 
         incoming().status == 'confirmed' &&
         (incoming().assignedWorkshopId == request.auth.uid || incoming().workshopId == request.auth.uid) &&
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'assignedWorkshopId', 'workshopId', 'updatedAt'])) ||

        // Action: Assigned Workshop Update (Status, Location, Chat)
        ((existing().assignedWorkshopId == request.auth.uid || existing().workshopId == request.auth.uid) && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'operativeLocation', 'updatedAt', 'messages', 'chatId']))
      );
    }

    // --- Chats ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn(); // Rely on parent path check? No, list needs it.
        allow list: if isSignedIn(); // We rely on client query filtering by participants in the message data or parent chat read access
        allow create: if isSignedIn() && 
          request.auth.uid == request.resource.data.senderId;
      }
    }
    
    // Legacy support
    match /missions/{missionId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }
  }
}
